OPENAI_API_KEY=#Add OpenAI API key here
DATA_DIR=data/scifact/data
RESULTS_DIR=results
SCIFACT_DB=data/scifact/scifact_corpus.db
SCIFACT_CACHE=data/scifact/factscore_cache
FACTSCORE_DATA=~/.cache/factscore
N_CLAIMS=10
RAND_SEED=42
FS_SUPPORT_THRESHOLD=0.6
FS_CONTRADICT_THRESHOLD=0.4
FS_NEI_ATOM_FRAC=0.60
FS_SMALL_SAMPLE_CONTRADICT_THRESHOLD=0.50
RELEVANCE_GATE_THRESHOLD=0.5
TOP_K_ABSTRACTS=3
UQLM_NUM_RESPONSES=5
NLI_TEMPERATURE=0.0
LABEL_SCAN_CHARS=80
SPECIAL_SEPARATOR=####SPECIAL####SEPARATOR####

# RoBERTa NLI classifier (fine-tuning + inference)
ROBERTA_MODEL=level3/finetuned_roberta
# Base checkpoint to fine-tune. Default is an NLI-pretrained RoBERTa-base that
# fits any machine. For higher F1 on a >=16 GB GPU, use roberta-large-mnli
# (on small/8 GB GPUs pair it with ROBERTA_OPTIM=adafactor + ROBERTA_GRAD_CHECKPOINT=1).
ROBERTA_BASE_MODEL=cross-encoder/nli-roberta-base
ROBERTA_MAX_LENGTH=256
ROBERTA_EPOCHS=4
ROBERTA_BATCH_SIZE=8
ROBERTA_LR=2e-5
ROBERTA_OPTIM=adamw_torch
ROBERTA_GRAD_CHECKPOINT=0
# Optional: class-weighted loss to up-weight rare classes. Tested and it did NOT
# help here (val macro-F1 dropped); left as an opt-in for other data splits.
ROBERTA_CLASS_WEIGHTS=0
# Premise for the NLI classifier (training + benchmark must match):
#   rationale = gold evidence sentences (standard SciFact label-prediction; oracle, higher F1)
#   abstract  = full cited abstract (harder end-to-end "retrieve context" setting)
PREMISE_MODE=rationale

# Benchmark harness (benchmark.py)
GPT35_MODEL=gpt-3.5-turbo
BENCHMARK_DATA=claims_dev.jsonl
BENCHMARK_CONCURRENCY=8
BENCHMARK_ATOMIC=0
BENCHMARK_ATOMIC_N=30

# Score classifier (RandomForest)
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=7
RF_RANDOM_STATE=42
CV_N_SPLITS=5

